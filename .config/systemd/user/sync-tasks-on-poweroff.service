# This service file has to be copied into /etc/systemd/system/
[Unit]
Description=Sync tasks at shutdown
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/task sync
User=anmomu92

[Install]
WantedBy=halt.target reboot.target shutdown.target
